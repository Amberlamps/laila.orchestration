{
  "name": "@laila/timeout-checker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Lambda function that checks for stale work assignments exceeding timeout thresholds",
  "main": "dist/handler.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@laila/database": "workspace:*",
    "@laila/logger": "workspace:*",
    "@laila/metrics": "workspace:*",
    "@laila/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}
