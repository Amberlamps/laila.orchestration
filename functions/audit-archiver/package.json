{
  "name": "@laila/audit-archiver",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Lambda function that archives old audit log entries from DynamoDB to S3",
  "main": "dist/handler.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@laila/logger": "workspace:*",
    "@laila/metrics": "workspace:*",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
