{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@laila/shared": ["../../packages/shared/src"],
      "@laila/shared/*": ["../../packages/shared/src/*"],
      "@laila/domain": ["../../packages/domain/src"],
      "@laila/domain/*": ["../../packages/domain/src/*"],
      "@laila/database": ["../../packages/database/src"],
      "@laila/database/*": ["../../packages/database/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "esModuleInterop": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", ".next"]
}
