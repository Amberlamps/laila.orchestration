# .env.example
# Environment variable template for the laila.works Orchestration Service
# Copy this file to .env and fill in the values
#
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]

# ============================================
# Database (Neon PostgreSQL)
# ============================================

# [REQUIRED] Primary connection string — uses connection pooler for serverless/edge runtime
# Format: postgresql://<user>:<password>@<endpoint-host>/<database>?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/dbname?sslmode=require

# [REQUIRED] Direct connection for running migrations (bypasses connection pooler)
# Format: postgresql://<user>:<password>@<endpoint-host>/<database>?sslmode=require
DATABASE_DIRECT_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/dbname?sslmode=require

# ============================================
# Authentication (Better Auth + Google OAuth)
# ============================================

# [REQUIRED] Secret key for signing sessions and tokens (minimum 32 characters)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here

# [REQUIRED] Google OAuth 2.0 Client ID
# Obtain from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# [REQUIRED] Google OAuth 2.0 Client Secret
# Obtain from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_SECRET=your-google-client-secret

# [REQUIRED] Base URL for Better Auth callback and redirect handling
# Format: http://localhost:3000 for local development
# Google OAuth redirect URI must be configured in Google Cloud Console as:
#   {BETTER_AUTH_URL}/api/auth/callback/google
BETTER_AUTH_URL=http://localhost:3000

# ============================================
# AWS (DynamoDB Audit Logging)
# ============================================
# In local development, credentials are provided via environment variables.
# In production, prefer IAM roles attached to the compute instance (ECS task role,
# Lambda execution role, etc.) and omit these variables entirely.

# [REQUIRED in local dev] AWS region for DynamoDB and other services
# Format: us-east-1, eu-west-1, etc.
AWS_REGION=us-east-1

# [REQUIRED in local dev] AWS access key for programmatic access
# In production, use IAM roles instead of static credentials
AWS_ACCESS_KEY_ID=your-aws-access-key-id

# [REQUIRED in local dev] AWS secret key for programmatic access
# In production, use IAM roles instead of static credentials
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# [REQUIRED] DynamoDB table name for audit log entries
# Format: <project>-<environment>-audit (e.g., laila-dev-audit)
DYNAMODB_AUDIT_TABLE_NAME=laila-dev-audit

# ============================================
# Application Settings
# ============================================

# [REQUIRED] Public-facing application URL exposed to the browser
# NOTE: Variables prefixed with NEXT_PUBLIC_ are bundled into the client-side
# JavaScript and visible to end users — never put secrets in NEXT_PUBLIC_ vars.
# Format: http://localhost:3000 for local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [OPTIONAL] Node environment (development | production | test)
# Defaults to "development" when not set
NODE_ENV=development

# [OPTIONAL] Number of bcrypt hash rounds for API key hashing
# Higher values are more secure but slower; 12 is a reasonable default
API_KEY_HASH_ROUNDS=12
